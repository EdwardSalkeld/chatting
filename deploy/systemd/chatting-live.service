[Unit]
Description=Chatting Live Automation Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=edward
Group=edward
WorkingDirectory=/home/edward/chatting
EnvironmentFile=/home/edward/chatting/configs/chatting-live.env
ExecStart=/usr/bin/python3 -m app.main --run-live
Restart=always
RestartSec=5
TimeoutStopSec=20
SyslogIdentifier=chatting-live

[Install]
WantedBy=multi-user.target
